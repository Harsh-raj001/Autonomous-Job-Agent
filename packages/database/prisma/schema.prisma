generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile        Profile?
  settings       Settings?
  resumes        Resume[]
  applications   Application[]
  analyses       ResumeAnalysis[]
  auditLogs      AuditLog[]
  digests        DailyDigest[]
  resumeTailors  ResumeTailor[]
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  headline    String?
  location    String?
  githubUrl   String?
  linkedinUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id                 String   @id @default(uuid())
  userId             String   @unique
  autoApplyThreshold Int      @default(80)
  dailyApplyLimit    Int      @default(10)
  emailNotifications Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id        String   @id @default(uuid())
  userId    String
  fileUrl   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parsedResume ParsedResume?
  applications Application[]
  resumeTailors ResumeTailor[]
}

model ParsedResume {
  id        String   @id @default(uuid())
  resumeId  String   @unique
  data      Json     // Structured JSON (education, experience, projects, skills)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  embedding Unsupported("vector(1536)")?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobSkills JobSkill[]
}

model Company {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]
}

model Job {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  description String
  url         String   @unique
  source      String
  postedAt    DateTime
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills       JobSkill[]
  applications Application[]
  analyses     ResumeAnalysis[]
  resumeTailors ResumeTailor[]
}

model JobSkill {
  id         String   @id @default(uuid())
  jobId      String
  skillId    String
  isRequired Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
}

model Application {
  id         String   @id @default(uuid())
  userId     String
  jobId      String
  resumeId   String
  status     String   @default("APPLIED") // APPLIED, REJECTED, INTERVIEW
  matchScore Int?
  appliedAt  DateTime @default(now())
  method     String   @default("AUTO")    // AUTO, MANUAL
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeAnalysis {
  id                String   @id @default(uuid())
  userId            String
  jobId             String
  scoreTotal        Int
  scoreBreakdown    Json
  explanation       String
  opportunityScore  String?  // e.g., High, Medium, Low
  hiringProbability String?  // e.g., High, Medium, Low
  competitionLevel  String?  // e.g., High, Medium, Low
  recommendedAction String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model ResumeTailor {
  id              String   @id @default(uuid())
  userId          String
  jobId           String
  originalResumeId String
  tailoredContent Json     // Structured representation of rewrites
  gapAnalysis     Json     // ATS gaps and suggestions
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  job            Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  originalResume Resume @relation(fields: [originalResumeId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model DailyDigest {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime @db.Date
  totalDiscovered Int      @default(0)
  totalApplied    Int      @default(0)
  status          String   @default("SENT") // SENT, FAILED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
